# Postgres connection string for property-search-app. Keep the
# PROPERTY_SEARCH_* prefix so these settings do not conflict with survey-app's
# JAMES_* variables in the same repo. DATABASE_URL remains supported as a
# compatibility fallback for Vercel/Neon integrations.
PROPERTY_SEARCH_DATABASE_URL=postgresql://user:***@host:5432/property_search

# Required in production for signed cookies/session boundaries.
PROPERTY_SEARCH_SESSION_SECRET=replace-with-a-long-random-secret

# Optional admin usernames for future audit screens.
PROPERTY_SEARCH_ADMIN_USERNAMES=admin,nikolaj

# Require a valid signed session before person-to-property searches. Defaults to
# true in production and false in local development unless explicitly set.
# Recommended Vercel production value: true
PROPERTY_SEARCH_REQUIRE_AUTH=true

# Live data integrations are disabled by default and must remain disabled in
# Vercel Preview/Production until docs/data-source-assessment.md and
# docs/source-approvals/<source>.md have an approved production gate for that
# source. Enable both the global switch and the source-specific switch.
PROPERTY_SEARCH_ENABLE_LIVE_SOURCES=false
PROPERTY_SEARCH_ENABLE_DAR=false
PROPERTY_SEARCH_ENABLE_BBR=false
PROPERTY_SEARCH_ENABLE_CVR=false
PROPERTY_SEARCH_ENABLE_OIS=false
PROPERTY_SEARCH_ENABLE_TINGLYSNINGEN=false
