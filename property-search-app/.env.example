# Postgres connection string for property-search-app. DATABASE_URL remains supported
# as a compatibility fallback for Vercel/Neon integrations.
PROPERTY_SEARCH_DATABASE_URL=postgresql://user:password@host:5432/property_search

# Required in production for signed cookies/session boundaries.
PROPERTY_SEARCH_SESSION_SECRET=replace-with-a-long-random-secret

# Optional admin usernames for future audit screens.
PROPERTY_SEARCH_ADMIN_USERNAMES=admin,nikolaj

# Live data integrations are disabled by default and must remain disabled until
# docs/data-source-assessment.md has an approved production gate for that source.
PROPERTY_SEARCH_ENABLE_LIVE_SOURCES=false
